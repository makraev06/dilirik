generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"  
}

model Resume {
  id          String   @id @default(cuid())
  userId      String?  
  fileName    String
  content     String   
  jobPosition String?  
  score       Int?     
  kelebihan   String[] 
  kekurangan  String[] 
  saran       String[] 
  details     Json?    
  feedback    String?  
  createdAt   DateTime @default(now())
}