// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Resume {
  id          String   @id @default(cuid())
  userId      String? // Persiapan untuk Prioritas 3 (Auth)
  fileName    String
  content     String
  jobPosition String? // Posisi yang dilamar
  score       Int?
  kelebihan   String[] // Array PostgreSQL untuk list kelebihan
  kekurangan  String[] // Array PostgreSQL untuk list kekurangan
  saran       String[] // Array PostgreSQL untuk list saran
  feedback    String? // Kolom lama dipertahankan
  createdAt   DateTime @default(now())
}
